Options -Indexes

DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Localhost: para aqui, nao redireciona nada.
    RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
    RewriteRule ^ - [L]

    # Producao: forca HTTPS com www.
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} !^www\.melhoresperfumesdf\.com\.br$ [NC]
    RewriteRule ^ https://www.melhoresperfumesdf.com.br%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
